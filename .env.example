# App
SHADE_CATALOG_ENV=local
SHADE_CATALOG_DEBUG=true

# Credentials must match the Postgres you connect to (port 5432 on this machine).
# If you use `docker compose` from this repo, see docker-compose.yml (default user/pass/db: shade / shade / shade_catalog).
# If you use another Postgres install, replace user, password, host, port, and database name below.

# Async URL for FastAPI + SQLAlchemy (asyncpg)
SHADE_CATALOG_DATABASE_URL=postgresql+asyncpg://shade:shade@127.0.0.1:5432/shade_catalog

# Sync URL for Alembic migrations (psycopg3)
SHADE_CATALOG_SYNC_DATABASE_URL=postgresql+psycopg://shade:shade@127.0.0.1:5432/shade_catalog

# Optional: if set, admin routes require Authorization: Bearer <this value>. If unset, admin is open (development only).
# SHADE_CATALOG_ADMIN_API_TOKEN=change-me

# Local upload storage (SVG/PDF). Directory is created on first upload.
# SHADE_CATALOG_UPLOAD_DIR=data/uploads
# SHADE_CATALOG_MAX_UPLOAD_BYTES=26214400
